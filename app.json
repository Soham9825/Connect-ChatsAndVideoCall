{
  "expo": {
    "name": "Connect",
    "slug": "Connect",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "connect",
    "userInterfaceStyle": "automatic",
    "ios": {
      "infoPlist": {
      "NSPhotoLibraryUsageDescription": "This app needs access to your photos to attach images to messages.",
      "NSCameraUsageDescription": "This app needs access to the camera to take photos for messages.",
      "NSPhotoLibraryAddUsageDescription": "This app needs permission to save photos to your library.",
      "NSMicrophoneUsageDescription": "This app needs access to the microphone for recording audio (if/when used)."
    },
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.Connect"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.Connect"
    },
    "web": {
      "output": "server",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@stream-io/video-react-native-sdk",
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "$(PRODUCT_NAME) requires camera access",
          "microphonePermission": "$(PRODUCT_NAME) requires microphone access"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24
          }
        }
      ],

      "expo-web-browser",
      "@stream-io/video-react-native-sdk",
      "expo-build-properties"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
